#!/usr/bin/env bash

set -e

VERSION="0.1.0"

SOURCE="${BASH_SOURCE[0]}"

while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"

    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

CORUJA_ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

cd "$CORUJA_ROOT"

source "${CORUJA_ROOT}/cli/core.sh"
source "${CORUJA_ROOT}/cli/commands/environment.sh"
source "${CORUJA_ROOT}/cli/commands/projects.sh"
source "${CORUJA_ROOT}/cli/commands/doctor.sh"
source "${CORUJA_ROOT}/cli/commands/database.sh"
source "${CORUJA_ROOT}/cli/commands/project.sh"
source "${CORUJA_ROOT}/cli/commands/services.sh"
source "${CORUJA_ROOT}/cli/commands/redis.sh"
source "${CORUJA_ROOT}/cli/commands/node.sh"

show_help() {
    show_header

    cat <<'EOF'
Uso:
  coruja <comando> [argumentos]

Ambiente:
  up                              Inicia o ambiente
  down                            Para o ambiente
  restart                         Reinicia os serviços
  build                           Reconstrói e inicia o ambiente
  status                          Exibe o estado dos containers
  logs [serviço]                  Exibe os logs
  shell                           Abre o Zsh no container PHP

Projetos:
  new <nome> [--template=<nome>]  Cria um projeto
  projects                        Lista os projetos
  project list                    Lista os projetos
  project info <nome>             Exibe informações do projeto
  project clone <origem> <destino>
                                  Duplica um projeto
  project remove <nome>           Remove um projeto

Exemplos:
  coruja new meu-projeto
  coruja new minha-api --template=php-mvc-basic

Banco de dados:
  db list                         Lista os bancos
  db create <nome>                Cria um banco
  db drop <nome>                  Exclui um banco
  db backup <banco>               Cria um backup SQL
  db restore <arquivo> [banco]    Restaura um backup SQL
  db shell                        Abre o terminal do MariaDB

Serviços:
  service status                  Lista os serviços
  service restart <nome>          Reinicia um serviço
  service logs <nome>             Exibe os logs de um serviço

Redis:
  redis ping                      Testa a conexão
  redis shell                     Abre o terminal Redis
  redis info                      Exibe informações do Redis
  redis flush                     Apaga os dados do Redis

Node.js:
  node [projeto] <argumentos>     Executa Node.js
  npm [projeto] <argumentos>      Executa npm
  npx [projeto] <argumentos>      Executa npx
  pnpm [projeto] <argumentos>     Executa pnpm
  yarn [projeto] <argumentos>     Executa Yarn

Sistema:
  doctor                          Verifica a saúde do ambiente
  version                         Exibe a versão
  help                            Exibe esta ajuda
EOF

    echo ""
}

case "${1:-help}" in
    up)
        command_up
        ;;

    down)
        command_down
        ;;

    restart)
        command_restart
        ;;

    build)
        command_build
        ;;

    status)
        command_status
        ;;

    logs)
        command_logs "${2:-}"
        ;;

    shell)
        command_shell
        ;;

    new)
        shift
        command_new "$@"
        ;;
    
    project)
        command_project "${2:-help}" "${3:-}" "${4:-}"
        ;;

    db)
        command_db "${2:-help}" "${3:-}" "${4:-}"
        ;;
    service)
        command_service "${2:-help}" "${3:-}"
        ;;

    redis)
        command_redis "${2:-help}" "${3:-}"
        ;;

    node|npm|npx|pnpm|yarn)
        node_tool="$1"
        shift

        node_run_tool "$node_tool" "$@"
        ;;

    doctor)
        command_doctor
        ;;

    version)
        echo "Coruja Dev Environment ${VERSION}"
        ;;

    help|-h|--help)
        show_help
        ;;

    *)
        echo "Comando desconhecido: ${1}"
        echo ""
        show_help
        exit 1
        ;;
esac