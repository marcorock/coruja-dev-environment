# Diretório raiz compartilhado pelo ambiente.
# WSL/Linux: /home/seu-usuario/www
# macOS: /Users/seu-usuario/www
CORUJA_HOME=/home/seu-usuario/www

# Diretórios persistentes usados pelo Docker e pela CLI.
PROJECTS_ROOT=/home/seu-usuario/www/projects
DB_DATA_PATH=/home/seu-usuario/www/data/mariadb
REDIS_DATA_PATH=/home/seu-usuario/www/data/redis
BACKUPS_PATH=/home/seu-usuario/www/backups
TEMPLATES_PATH=/home/seu-usuario/www/templates

# Portas publicadas no host.
HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8082
DB_PORT=3306

# Credenciais locais do MariaDB.
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=development
MARIADB_USER=developer
MARIADB_PASSWORD=developer

# Confirme no WSL/Linux com: id -u && id -g
# No macOS, mantenha os valores padrão inicialmente.
USER_UID=1000
USER_GID=1000