# Caminho absoluto da pasta que contém todos os projetos.
# Exemplo WSL: /home/seu-usuario/www/projects
PROJECTS_ROOT=/home/seu-usuario/www/projects

HTTP_PORT=8080
PHPMYADMIN_PORT=8081
DB_PORT=3306

DB_DATA_PATH=./data/mariadb

MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=development
MARIADB_USER=developer
MARIADB_PASSWORD=developer

# Confirme no WSL com: id -u && id -g
USER_UID=1000
USER_GID=1000
