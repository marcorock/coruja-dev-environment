#!/usr/bin/env bash

set -e

PROJECT_NAME="${1:-}"
TEMPLATE_NAME="${2:-php-mvc-basic}"

if [ -z "$PROJECT_NAME" ]; then
    echo "Uso: ./scripts/new-project nome-do-projeto"
    exit 1
fi

if ! [[ "$PROJECT_NAME" =~ ^[a-z0-9-]+$ ]]; then
    echo "Use apenas letras minúsculas, números e hífens."
    exit 1
fi

if ! [[ "$TEMPLATE_NAME" =~ ^[a-z0-9-]+$ ]]; then
    echo "Nome de template inválido: ${TEMPLATE_NAME}"
    echo "Use apenas letras minúsculas, números e hífens."
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENVIRONMENT_DIR="$(dirname "$SCRIPT_DIR")"

TEMPLATE_DIR="${ENVIRONMENT_DIR}/project-templates/${TEMPLATE_NAME}"
TEMPLATE_FILES_DIR="${TEMPLATE_DIR}/files"
TEMPLATE_CONFIG_FILE="${TEMPLATE_DIR}/template.conf"

cd "$ENVIRONMENT_DIR"

if [ ! -f ".env" ]; then
    echo "Arquivo .env não encontrado."
    exit 1
fi

if [[ ! -d "$TEMPLATE_DIR" ]]; then
    echo "Template não encontrado: ${TEMPLATE_NAME}"
    echo
    echo "Templates disponíveis:"

    for template_path in "${ENVIRONMENT_DIR}/project-templates"/*; do
        [[ -d "$template_path" ]] || continue
        echo "  $(basename "$template_path")"
    done

    exit 1
fi

if [[ ! -f "$TEMPLATE_CONFIG_FILE" ]]; then
    echo "Configuração do template não encontrada:"
    echo "  ${TEMPLATE_CONFIG_FILE}"
    exit 1
fi

if [[ ! -d "$TEMPLATE_FILES_DIR" ]]; then
    echo "Arquivos do template não encontrados:"
    echo "  ${TEMPLATE_FILES_DIR}"
    exit 1
fi

set -a
source "$TEMPLATE_CONFIG_FILE"
set +a

render_template() {
    local source_file="$1"
    local target_file="$2"
    local content

    if [[ ! -f "$source_file" ]]; then
        echo "Arquivo de template não encontrado:"
        echo "  ${source_file}"
        return 1
    fi

    content="$(cat "$source_file")"

    content="${content//'{{PROJECT_NAME}}'/$PROJECT_NAME}"
    content="${content//'{{DATABASE_NAME}}'/$DATABASE_NAME}"
    content="${content//'{{MARIADB_USER}}'/$MARIADB_USER}"
    content="${content//'{{MARIADB_PASSWORD}}'/$MARIADB_PASSWORD}"

    printf '%s\n' "$content" > "$target_file"
}

set -a
source "${ENVIRONMENT_DIR}/.env"
source "${ENVIRONMENT_DIR}/config/coruja.conf"
set +a

PROJECT_PATH="${CORUJA_PROJECTS_DIR}/${PROJECT_NAME}"
DATABASE_NAME="${PROJECT_NAME//-/_}"

if [ -d "$PROJECT_PATH" ]; then
    echo "O projeto já existe: $PROJECT_PATH"
    exit 1
fi

echo "Criando projeto: $PROJECT_NAME"

echo "Aplicando template: ${TEMPLATE_NAME}"
echo "Descrição: ${TEMPLATE_DESCRIPTION:-sem descrição}"

mkdir -p "$PROJECT_PATH"

cp -R "${TEMPLATE_FILES_DIR}/." "$PROJECT_PATH/"

render_template \
    "${PROJECT_PATH}/composer.json.tpl" \
    "${PROJECT_PATH}/composer.json"

render_template \
    "${PROJECT_PATH}/env.tpl" \
    "${PROJECT_PATH}/.env"

render_template \
    "${PROJECT_PATH}/gitignore.tpl" \
    "${PROJECT_PATH}/.gitignore"

rm \
    "${PROJECT_PATH}/composer.json.tpl" \
    "${PROJECT_PATH}/env.tpl" \
    "${PROJECT_PATH}/gitignore.tpl"

echo "Criando banco: $DATABASE_NAME"

docker compose exec -T database mariadb \
    -uroot \
    -p"${MARIADB_ROOT_PASSWORD}" <<EOF
CREATE DATABASE IF NOT EXISTS \`${DATABASE_NAME}\`
CHARACTER SET utf8mb4
COLLATE utf8mb4_unicode_ci;

GRANT ALL PRIVILEGES ON \`${DATABASE_NAME}\`.* TO '${MARIADB_USER}'@'%';

FLUSH PRIVILEGES;
EOF

echo "Instalando dependências do Composer"

docker compose exec -T \
    --user developer \
    -e HOME=/home/developer \
    -e COMPOSER_HOME=/home/developer/.composer \
    -w "/var/www/projects/${PROJECT_NAME}" \
    web composer install

echo ""
echo "Projeto criado com sucesso."
echo "Pasta: ${PROJECT_PATH}"
echo "Banco: ${DATABASE_NAME}"
echo "Endereço: http://${PROJECT_NAME}.localhost"
